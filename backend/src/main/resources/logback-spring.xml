<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- GP_DATA_DIR is set by the Tauri shell (app data dir); falls back to ./logs when unset,
         e.g. for local `mvn spring-boot:run` / `java -jar` without a shell. -->
    <property name="LOG_DIR" value="${GP_DATA_DIR:-.}/logs"/>

    <property name="LOG_PATTERN"
              value="%d{yyyy-MM-dd'T'HH:mm:ss.SSSXXX} %-5level [%thread] %logger{36} - %msg%n"/>

    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/backend.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/backend-%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>14</maxHistory>
            <totalSizeCap>200MB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- dev profile: normal console logging is fine (npm run dev, plain terminal, no handshake). -->
    <springProfile name="dev">
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>${LOG_PATTERN}</pattern>
            </encoder>
        </appender>
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
        </root>
    </springProfile>

    <!-- default profile: stdout must stay clean (WARN+ only) so the shell can find the single
         GP_READY handshake line without noise; full detail still goes to the file. -->
    <springProfile name="!dev">
        <appender name="CONSOLE_WARN" class="ch.qos.logback.core.ConsoleAppender">
            <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
                <level>WARN</level>
            </filter>
            <encoder>
                <pattern>${LOG_PATTERN}</pattern>
            </encoder>
        </appender>
        <root level="INFO">
            <appender-ref ref="CONSOLE_WARN"/>
            <appender-ref ref="FILE"/>
        </root>
    </springProfile>

</configuration>
